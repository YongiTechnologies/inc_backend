PORT=5000
NODE_ENV=development

# MongoDB — use MongoDB Atlas free tier
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net
DB_NAME=ghana_logistics

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m

# CORS — comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Email (Nodemailer) — optional, for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Ghana Logistics Co. <no-reply@ghanalogistics.com>
CONTACT_EMAIL=support@ghanalogistics.com

# Google OAuth 2.0 — for Google Sign-In
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# GPS Tracking (optional — only needed if using physical GPS devices)
# Shared secret GPS providers use to authenticate their webhooks
GPS_WEBHOOK_SECRET=your_gps_webhook_secret_here

# Google Maps API key — used for:
#   1. Reverse geocoding GPS pings to city/country names
#   2. Rendering the map on the frontend (Maps JavaScript API)
# Get one at: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# GPS Provider — which adapter to use: traccar | google | here | raw
GPS_PROVIDER=raw
